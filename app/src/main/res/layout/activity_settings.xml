<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="← Back"
            android:textColor="#FFFFFF"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <TextView
            android:id="@+id/tvSettingsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙ Setting"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View android:layout_width="80dp" android:layout_height="1dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="vertical">

            <!-- Reading Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvReadingSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tùy chọn đọc tài liệu"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchKeepScreenOn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 Luôn giữ sáng màn hình khi đọc"
                    android:textSize="14sp"
                    android:textColor="#333333" />
            </LinearLayout>

            <!-- Metadata Colors Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvMetadataColorTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎨 Màu hiển thị (自社品番, 品番, 自社品名, 品名)"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvMetadataColorDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mặc định nhãn màu xám, giá trị màu nổi bật. Bấm để chọn màu riêng biệt:"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="12dp" />

                <!-- 自社品番 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="自社品番"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#333333" />
                    <TextView
                        android:id="@+id/btnLabelJishaHinban"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhãn"
                        android:textSize="12sp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/btnValueJishaHinban"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá trị"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp" />
                </LinearLayout>

                <!-- 品番 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="品番"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#333333" />
                    <TextView
                        android:id="@+id/btnLabelHinban"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhãn"
                        android:textSize="12sp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/btnValueHinban"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá trị"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp" />
                </LinearLayout>

                <!-- 自社品名 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="自社品名"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#333333" />
                    <TextView
                        android:id="@+id/btnLabelJishaHinmei"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhãn"
                        android:textSize="12sp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/btnValueJishaHinmei"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá trị"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp" />
                </LinearLayout>

                <!-- 品名 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="品名"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#333333" />
                    <TextView
                        android:id="@+id/btnLabelHinmei"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhãn"
                        android:textSize="12sp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/btnValueHinmei"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá trị"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Update Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/tvUpdateSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cập nhật ứng dụng"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvCurrentVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Phiên bản hiện tại: v1.0.0"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnCheckUpdate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔄 Kiểm tra cập nhật"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <TextView
                    android:id="@+id/tvUpdateStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutDownloadProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <ProgressBar
                        android:id="@+id/pbDownload"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="0" />

                    <TextView
                        android:id="@+id/tvProgressPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="0%"
                        android:textSize="12sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnDownloadUpdate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="📥 Tải về"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
